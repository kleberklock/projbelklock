datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Loja {
  id           String             @id @default("default-loja")
  nome         String             @default("Loja Padrão")
  cnpj         String?            @unique
  createdAt    DateTime           @default(now())
  usuarios     Usuario[]
  produtos     Produto[]
  consignados  Consignado[]
  historicos   HistoricoAcerto[]
  vendasDireta VendaDireta[]
  vendasRev    VendaRevendedora[]
  clientes     Cliente[]
  configuracao Configuracao[]
  notificacoes Notificacao[]
  faixasComissao FaixaComissao[]
}

model Usuario {
  id           String             @id @default(uuid())
  lojaId       String?            // Opcional: SUPER_ADMIN não pertence a nenhuma loja específica
  loja         Loja?              @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  nome         String
  email        String             @unique
  pin          String?            @unique // Código PIN de 4 dígitos para revendedoras
  senhaHash    String
  role         String             // Roles: "SUPER_ADMIN" | "ADMIN_LOJA" | "VENDEDORA"
  whatsapp     String?
  comissao     Float              @default(30.0) // padrão 30%
  
  // Novas configurações de comissão e regras personalizadas
  tipoComissao   String             @default("FIXA") // "FIXA" | "PROGRESSIVA" | "META_UNICA"
  metaUnicaValor Float              @default(0.0)
  metaUnicaBonus Float              @default(0.0) 
  metaUnicaTipoBonus String         @default("PERCENTUAL") // "PERCENTUAL" | "FIXO"
  baseCalculo    String             @default("BRUTO") // "BRUTO" | "LIQUIDO"
  regraPerda     String             @default("VALOR_VENDA") // "VALOR_VENDA" | "VALOR_CUSTO" | "ISENTO"
  limiteIsencaoPerda Int            @default(0)
  periodoAcumulo String             @default("MANUAL") // "MANUAL" | "MENSAL"

  // Campos para onboarding e documentos
  documentoRg         String?
  documentoCpf        String?
  documentoEndereco   String?
  termoAssinado       Boolean             @default(false)
  respostaOnboarding  RespostaOnboarding?
  documentos          DocumentoUsuario[]
  termosConsignacao   TermoConsignacao[]
  linksPagamento      LinkPagamento[]

  consignados  Consignado[]
  historico    HistoricoAcerto[]
  vendas       VendaRevendedora[]
  createdAt    DateTime           @default(now())
  faixasComissao FaixaComissao[]
}

model Produto {
  id                 String        @id @default(uuid())
  lojaId             String        @default("default-loja")
  loja               Loja          @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  codigo             String        @unique
  nome               String
  categoria          String
  quantidade         Int           @default(0) // estoque no centro de distribuição
  quantidadeDefeito  Int           @default(0) // peças devolvidas com defeito
  custoBruto         Float         @default(0.0)
  custoBanho         Float         @default(0.0)
  custoLiquido       Float         @default(0.0)
  markup             Float         @default(3.0)
  fotoUrl            String?
  consignados        Consignado[]
  createdAt          DateTime      @default(now())
}

model Consignado {
  id                   String   @id @default(uuid())
  lojaId               String   @default("default-loja")
  loja                 Loja     @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  usuarioId            String
  produtoId            String
  quantidadeConsignada Int
  precoVenda           Float
  usuario              Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  produto              Produto  @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  createdAt            DateTime @default(now())

  @@unique([usuarioId, produtoId])
}

model HistoricoAcerto {
  id                 String   @id @default(uuid())
  lojaId             String   @default("default-loja")
  loja               Loja     @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  usuarioId          String
  data               DateTime @default(now())
  totalConsignada    Int
  totalVendida       Int
  totalDevolvida     Int
  totalPerdida       Int      @default(0)
  totalDefeito       Int      @default(0)
  faturamentoBruto   Float
  valorDescontoPerda Float    @default(0.0)
  comissaoPaga       Float
  liquidoBelklock    Float
  formaPagamento     String?  @default("Pix")

  // Novos campos de controle financeiro do acerto
  totalRetidoRevendedora Float    @default(0.0)
  totalRecebidoAdmin     Float    @default(0.0)
  saldoFinalAcerto       Float    @default(0.0)

  usuario            Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}

model VendaDireta {
  id              String   @id @default(uuid())
  lojaId          String   @default("default-loja")
  loja            Loja     @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  data            DateTime @default(now())
  codigo          String
  nome            String
  preco           Float
  whatsappCliente String?
  nomeCliente     String?
  clienteId       String?
  cliente         Cliente? @relation(fields: [clienteId], references: [id])
}

model VendaRevendedora {
  id            String   @id @default(uuid())
  lojaId        String   @default("default-loja")
  loja          Loja     @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  data          DateTime @default(now())
  usuarioId     String
  produtoId     String
  nomeProduto   String
  codigoProduto String
  quantidade    Int
  precoVenda    Float
  comissaoValor Float
  clienteId     String?
  cliente       Cliente? @relation(fields: [clienteId], references: [id])

  // Novos campos para controle de links de pagamento e canal
  canalPagamento  String             @default("DINHEIRO_REVENDEDORA") // "LINK_PAGO_ADMIN" | "DINHEIRO_REVENDEDORA"
  pago            Boolean            @default(true)
  linkPagamentoId String?

  usuario       Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}

model Cliente {
  id               String             @id @default(uuid())
  lojaId           String             @default("default-loja")
  loja             Loja               @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  nome             String
  whatsapp         String             @unique
  dataNascimento   String?
  observacoes      String?
  vendas           VendaDireta[]
  vendasRevendedora VendaRevendedora[]
  linksPagamento    LinkPagamento[]
  createdAt        DateTime           @default(now())
}

model LogAcao {
  id          String   @id @default(uuid())
  usuarioId   String?
  usuarioNome String?
  acao        String
  detalhes    String
  data        DateTime @default(now())
}

model Notificacao {
  id        String   @id @default(uuid())
  lojaId    String   @default("default-loja")
  loja      Loja     @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  tipo      String   // "venda_revendedora", "acerto", etc.
  mensagem  String
  detalhes  String?  // JSON string contendo detalhes
  lida      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Configuracao {
  id            String   @id @default(uuid())
  lojaId        String   @default("default-loja")
  loja          Loja     @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  nomeEmpresa   String   @default("BelKlock Semijoias")
  logoUrl       String   @default("")
  corPrimaria   String   @default("#d4af37")
  corSecundaria String   @default("#111111")
  bgPrimary     String   @default("#0a0a0a")
  bgCard        String   @default("#121212")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model FaixaComissao {
  id         String   @id @default(uuid())
  lojaId     String?
  loja       Loja?    @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  usuarioId  String?
  usuario    Usuario? @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  valorMin   Float    @default(0.0)
  valorMax   Float
  percentual Float
}

model RespostaOnboarding {
  id                 String   @id @default(uuid())
  usuarioId          String   @unique
  usuario            Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  vendedoraPrincipal String
  comoConheceu       String
  experienciaVendas  String
  comentarios        String?
  createdAt          DateTime @default(now())
}

model LinkPagamento {
  id             String   @id @default(uuid())
  usuarioId      String
  usuario        Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  clienteId      String?
  cliente        Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  valor          Float
  formaEnvio     String   // "PIX" | "BOLETO" | "CARTAO"
  status         String   @default("PENDENTE") // "PENDENTE" | "PAGO" | "EXPIRADO"
  linkSimulado   String
  vendaId        String?  // Id da venda associada, se houver
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model MensagemWhatsapp {
  id        String   @id @default(uuid())
  lojaId    String   @default("default-loja")
  numero    String
  mensagem  String
  tipo      String   // "BOAS_VINDAS" | "ACERTO" | "REINICIO_COMISSAO"
  status    String   @default("PENDENTE") // "PENDENTE" | "ENVIADO" | "ERRO"
  createdAt DateTime @default(now())
}

model DocumentoUsuario {
  id          String   @id @default(uuid())
  usuarioId   String
  usuario     Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  tipo        String   // "RG" | "CPF" | "COMPROVANTE_RESIDENCIA"
  nomeArquivo String
  caminhoUrl  String
  createdAt   DateTime @default(now())
}

model TermoConsignacao {
  id             String   @id @default(uuid())
  usuarioId      String
  usuario        Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  titulo         String
  conteudo       String
  status         String   @default("PENDENTE") // "PENDENTE" | "ASSINADO"
  assinaturaNome String?
  assinaturaCpf  String?
  assinaturaIp   String?
  dataAssinatura DateTime?
  prazoDevolucao DateTime?
  createdAt      DateTime @default(now())
}

model Treinamento {
  id        String   @id @default(uuid())
  lojaId    String   @default("default-loja")
  titulo    String
  descricao String?
  tipo      String   // "VIDEO" | "PDF"
  url       String
  createdAt DateTime @default(now())
}
