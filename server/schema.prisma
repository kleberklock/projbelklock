datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Usuario {
  id           String             @id @default(uuid())
  nome         String
  email        String             @unique
  pin          String?            @unique // Código PIN de 4 dígitos para revendedoras
  senhaHash    String
  role         String             // "admin" ou "revendedora"
  whatsapp     String?
  comissao     Float              @default(30.0) // padrão 30%
  consignados  Consignado[]
  historico    HistoricoAcerto[]
  vendas       VendaRevendedora[]
  createdAt    DateTime           @default(now())
}

model Produto {
  id                 String        @id @default(uuid())
  codigo             String        @unique
  nome               String
  categoria          String
  quantidade         Int           @default(0) // estoque no centro de distribuição
  quantidadeDefeito  Int           @default(0) // peças devolvidas com defeito
  custoBruto         Float         @default(0.0)
  custoBanho         Float         @default(0.0)
  custoLiquido       Float         @default(0.0)
  markup             Float         @default(3.0)
  fotoUrl            String?
  consignados        Consignado[]
  createdAt          DateTime      @default(now())
}

model Consignado {
  id                   String   @id @default(uuid())
  usuarioId            String
  produtoId            String
  quantidadeConsignada Int
  precoVenda           Float
  usuario              Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  produto              Produto  @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  createdAt            DateTime @default(now())

  @@unique([usuarioId, produtoId])
}

model HistoricoAcerto {
  id                String   @id @default(uuid())
  usuarioId         String
  data              DateTime @default(now())
  totalConsignada   Int
  totalVendida      Int
  totalDevolvida    Int
  totalPerdida      Int      @default(0)
  totalDefeito      Int      @default(0)
  faturamentoBruto  Float
  valorDescontoPerda Float   @default(0.0)
  comissaoPaga      Float
  liquidoBelklock   Float
  usuario           Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}

model VendaDireta {
  id              String   @id @default(uuid())
  data            DateTime @default(now())
  codigo          String
  nome            String
  preco           Float
  whatsappCliente String?
  nomeCliente     String?
  clienteId       String?
  cliente         Cliente? @relation(fields: [clienteId], references: [id])
}

model VendaRevendedora {
  id            String   @id @default(uuid())
  data          DateTime @default(now())
  usuarioId     String
  produtoId     String
  nomeProduto   String
  codigoProduto String
  quantidade    Int
  precoVenda    Float
  comissaoValor Float
  clienteId     String?
  cliente       Cliente? @relation(fields: [clienteId], references: [id])
  usuario       Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}

model Cliente {
  id               String             @id @default(uuid())
  nome             String
  whatsapp         String             @unique
  dataNascimento   String?
  observacoes      String?
  vendas           VendaDireta[]
  vendasRevendedora VendaRevendedora[]
  createdAt        DateTime           @default(now())
}
