# ============================================================
#  CONECTA JOIAS — Variáveis de Ambiente (EXEMPLO)
#  Copie este arquivo para .env e preencha com seus valores.
#  NUNCA commite o arquivo .env com credenciais reais!
# ============================================================

# ── Servidor ──────────────────────────────────────────────
PORT=5000

# ── JWT (use uma chave aleatória forte em produção) ───────
# Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=coloque_uma_chave_secreta_forte_e_aleatoria_aqui

# ── Banco de Dados ─────────────────────────────────────────
# SQLite (desenvolvimento local)
DATABASE_URL="file:./dev.db"
# PostgreSQL (produção) — descomente e preencha:
# DATABASE_URL="postgresql://usuario:senha@host:5432/nome_banco"

# ── Azure Blob Storage (upload de imagens) ─────────────────
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=SEU_ACCOUNT;AccountKey=SUA_CHAVE;EndpointSuffix=core.windows.net"
AZURE_STORAGE_CONTAINER_NAME="semijoias"

# ── ASAAS (Gateway de Pagamentos PIX/Boleto/Cartão) ────────
# Chave de API do ASAAS (sandbox ou produção)
ASAAS_API_KEY="coloque_sua_api_key_do_asaas_aqui"
# Sandbox:   https://sandbox.asaas.com/api/v3
# Produção:  https://www.asaas.com/api/v3
ASAAS_API_URL="https://sandbox.asaas.com/api/v3"

# ── Frontend (CORS) ────────────────────────────────────────
# URL do frontend em produção (para liberar CORS corretamente)
FRONTEND_URL=http://localhost:8080

# ── SuperAdmin da Plataforma (criado automaticamente) ──────
SUPER_ADMIN_EMAIL=superadmin@plataforma.com
SUPER_ADMIN_SENHA=admin0001
SUPER_ADMIN_PIN=0001

# ── WhatsApp API (opcional) ────────────────────────────────
# Compatível com Z-API, Evolution API ou similar
# Deixe vazio para desabilitar o envio de WhatsApp
WHATSAPP_API_URL=""
WHATSAPP_API_KEY=""
