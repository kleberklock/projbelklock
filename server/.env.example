# Configuração da Porta do Servidor
PORT=5000

# Chave secreta de encriptação para tokens JWT (OBRIGATÓRIO - deve ser definida e segura)
JWT_SECRET=defina_uma_chave_secreta_super_segura_aqui

# URL do frontend para permissão de CORS (Padrão local: http://localhost:5500)
FRONTEND_URL=http://localhost:5500

# URL de Conexão com o Banco de Dados (PostgreSQL)
# Exemplo local: postgresql://postgres:senha123@localhost:5432/conectajoias?schema=public
# Exemplo Supabase/Railway: postgresql://postgres.xxxx:senha@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://usuario:senha@host:5432/banco?schema=public"

# Conexão com o Azure Blob Storage (Para fotos do Feed e Produtos)
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=belklockstorage;AccountKey=CHAVE_AQUI;EndpointSuffix=core.windows.net"
AZURE_STORAGE_CONTAINER_NAME="semijoias"

# ==============================
# Configurações do Gateway ASAAS (Pagamentos)
# ==============================
# Chave de API gerada no painel do ASAAS (Configurações > Integrações)
ASAAS_API_KEY="insira_sua_api_key_do_asaas_aqui"
# Use 'https://sandbox.asaas.com/api/v3' para testes e 'https://api.asaas.com/v3' para produção
ASAAS_API_URL="https://sandbox.asaas.com/api/v3"

