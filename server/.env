# Configuração da Porta do Servidor
PORT=5000

# Chave secreta de encriptação para tokens JWT (substituir em produção)
JWT_SECRET=b1dac369c32b5addcf66feaf9ed668b2bd2d0131ae8a9ce9d967ed115168d20c

# URL de Conexão (Usando SQLite local para testes no computador)
DATABASE_URL="file:./dev.db"

# Conexão com o Azure Blob Storage (Para fotos do Feed e Produtos)
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=belklockstorage;AccountKey=CHAVE_AQUI;EndpointSuffix=core.windows.net"
AZURE_STORAGE_CONTAINER_NAME="semijoias"

# Configurações do Gateway ASAAS (Pagamentos)
ASAAS_API_KEY="insira_sua_api_key_do_asaas_aqui"
ASAAS_API_URL="https://sandbox.asaas.com/api/v3"

# ==============================
# Configurações da Plataforma White-Label
# ==============================
# Nome padrão da empresa (usado para novas lojas e fallback)
NOME_EMPRESA_PADRAO=BelKlock Semijoias

# URL do Frontend (para CORS em produção)
FRONTEND_URL=http://localhost:5500

# ==============================
# Credenciais do SUPER_ADMIN (Criado automaticamente no startup)
# ==============================
SUPER_ADMIN_EMAIL=superadmin@plataforma.com
SUPER_ADMIN_SENHA=admin0001
SUPER_ADMIN_PIN=0001

# ==============================
# Configurações do Gateway de WhatsApp (Z-API, Evolution, etc.)
# ==============================
# Exemplo Z-API: https://api.z-api.io/instances/SUA_INSTANCIA/token/SEU_TOKEN/send-messages
WHATSAPP_API_URL=""
WHATSAPP_API_KEY=""
